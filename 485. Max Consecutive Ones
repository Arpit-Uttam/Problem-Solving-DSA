// Brute Force Approach
class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int n=nums.length;
        int sum=0;
        int max=Integer.MIN_VALUE;
        for(int i=0;i<n;i++){
            if(nums[i]==1) sum+=1;
            max=Math.max(max,sum);
            if(nums[i]==0) sum=0;
        }
        return max;
    }
}
