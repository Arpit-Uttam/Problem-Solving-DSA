//Optimised Solution using Kadane's Algorithm
class Solution {
    public int maxSubArray(int[] nums) {
       int n=nums.length;
       int sum=Integer.MIN_VALUE;
       int cs=0;
       for(int i=0;i<n;i++){
        cs+=nums[i];
        sum=Math.max(cs,sum);
        if(cs<0) cs=0;
       } 
       return sum;
    }
}
