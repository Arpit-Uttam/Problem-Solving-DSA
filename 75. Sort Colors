//leetcode Problem no. 75 Sort Colors
class Solution {
    public void sortColors(int[] nums) {
        int n=nums.length;
        int one=0;
        int zero=0;
        int two=0;
        if(n>1){
        for(int i =0;i<n;i++){
            if(nums[i]==0) zero+=1;
            else if(nums[i]==1) one+=1;
            else two+=1;
        }
        for(int i=0;i<n;i++){
            if(i<zero) nums[i]=0;
            else if(i<zero+one && i>=zero) nums[i]=1;
            else nums[i]=2;
        }
        }
    }
}
